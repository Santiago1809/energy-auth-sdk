{
  "name": "energy-community-auth-sdk",
  "version": "0.2.6",
  "description": "Typed JS/TS SDK for energy-community-auth auth_service",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Santiago1809/energy-auth-sdk.git"
  },
  "private": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "auth",
    "sdk",
    "typescript",
    "jwt",
    "nestjs"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "vitest": "^4.1.5",
    "tsup": "^8.2.4",
    "typescript": "^5.7.3",
    "vitest": "^4.1.5"
  }
}
